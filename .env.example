# ========================================
# Database
# ========================================
POSTGRES_USER=pythoncoach
POSTGRES_PASSWORD=pythoncoach_secret
POSTGRES_DB=pythoncoach
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pythoncoach:pythoncoach_secret@localhost:5432/pythoncoach

# ========================================
# Redis (optional, for caching)
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# JWT
# ========================================
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========================================
# AI Provider
# ========================================
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (OpenAI-compatible, set AI_PROVIDER=deepseek or openai)
# AI_PROVIDER=deepseek
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Alternative: Claude
# AI_PROVIDER=claude
# CLAUDE_API_KEY=sk-ant-your-claude-key
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ========================================
# Code Runner
# ========================================
CODE_RUNNER_TIMEOUT_SECONDS=5
CODE_RUNNER_MEMORY_LIMIT_MB=128
CODE_RUNNER_CPU_LIMIT=0.5
# Set to true when Docker Desktop is running. Requires: docker-compose build code-runner
CODE_RUNNER_USE_DOCKER=false
CODE_RUNNER_IMAGE=pythoncoach/code-runner:latest

# ========================================
# Frontend
# ========================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
